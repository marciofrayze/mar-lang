app EnrollmentApi

entity Student {
  name: String

  authorize read, create, update, delete when anonymous or user_authenticated
}

entity Course {
  title: String

  authorize read, create, update, delete when anonymous or user_authenticated
}

entity Enrollment {
  belongs_to Student
  belongs_to Course
  enrolled_at: DateTime

  authorize read, create, update, delete when anonymous or user_authenticated
}
